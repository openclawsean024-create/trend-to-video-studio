{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@trend-to-video-studio/core": ["app/lib/core.ts"],
      "@trend-to-video-studio/providers": ["app/lib/providers.ts"]
    }
  }
}
