# Repository driver
TREND_TO_VIDEO_REPOSITORY_DRIVER=json
# TREND_TO_VIDEO_SQLITE_FILE=.data/project-snapshot.sqlite
# TREND_TO_VIDEO_DATA_FILE=.data/project-snapshot.json

# Optional default providers
# TREND_TO_VIDEO_DEFAULT_VIDEO_PROVIDER=env-webhook-video
# TREND_TO_VIDEO_DEFAULT_UPLOAD_PROVIDER=env-webhook-upload

# Real generation provider via generic webhook/API endpoint
# Expected request body: { "prompt": string }
# Expected JSON response: { "jobId"?: string, "status"?: "queued"|"completed", "outputUrl"?: string, "videoUrl"?: string }
# TREND_TO_VIDEO_GENERATION_ENDPOINT=https://your-generation-endpoint.example.com/generate
# TREND_TO_VIDEO_GENERATION_API_KEY=replace-me

# Real upload provider via generic webhook/API endpoint
# Expected request body:
# {
#   "videoUrl": string,
#   "title": string,
#   "description": string,
#   "scheduledFor"?: string,
#   "platform": "youtube"
# }
# Expected JSON response: { "jobId"?: string, "status"?: "queued"|"completed", "remoteUrl"?: string, "uploadUrl"?: string }
# TREND_TO_VIDEO_UPLOAD_ENDPOINT=https://your-upload-endpoint.example.com/upload
# TREND_TO_VIDEO_UPLOAD_API_KEY=replace-me
